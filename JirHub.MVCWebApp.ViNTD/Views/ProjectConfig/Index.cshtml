@using JirHub.MVCWebApp.ViNTD.Models
@model SaveProjectConfigDto

@{
    ViewData["Title"] = "Configuration Details";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-8">
            <h2 class="text-primary"><i class="fas fa-cogs me-2"></i>Project Configuration</h2>
            <p class="text-muted">Current integration settings for your group.</p>
        </div>
        <div class="col-4 text-end align-self-center">
             <!-- Placeholder for top-level actions if needed in future -->
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Config Cards -->
    <div class="row g-4">
        <!-- Jira Section -->
        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fab fa-jira me-2"></i>Jira Integration</h5>
                    <a asp-action="EditJira" class="btn btn-sm btn-light text-primary fw-bold">
                        <i class="fas fa-pen me-1"></i> Edit
                    </a>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Jira URL</dt>
                        <dd class="col-sm-8 text-break">
                            @if (!string.IsNullOrEmpty(Model.JiraUrl))
                            {
                                <a href="@Model.JiraUrl" target="_blank" class="text-decoration-none">@Model.JiraUrl <i class="fas fa-external-link-alt small ms-1"></i></a>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Not configured</span>
                            }
                        </dd>

                        <dt class="col-sm-4 text-muted">Account Email</dt>
                        <dd class="col-sm-8">@(Model.JiraEmail ?? "Not configured")</dd>

                        <dt class="col-sm-4 text-muted">Project Key</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.JiraProjectKey))
                            {
                                <span class="badge bg-info text-dark">@Model.JiraProjectKey</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Not configured</span>
                            }
                        </dd>

                        <dt class="col-sm-4 text-muted">API Token</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.JiraApiToken))
                            {
                                <span class="text-muted fst-italic">••••••••••••••••</span>
                                <small class="d-block text-success"><i class="fas fa-shield-alt me-1"></i>Encrypted</small>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Not configured</span>
                            }
                        </dd>
                    </dl>
                    
                    <div class="mt-3">
                        <button type="button" class="btn btn-outline-info btn-sm w-100" id="checkJiraHealthBtn">
                            <i class="fas fa-stethoscope me-1"></i> Check Health
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- GitHub Section -->
        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fab fa-github me-2"></i>GitHub Integration</h5>
                    <a asp-action="EditGithubToken" class="btn btn-sm btn-light text-dark fw-bold">
                        <i class="fas fa-pen me-1"></i> Edit Token
                    </a>
                </div>
                <div class="card-body">
                    <dl class="row mb-3">
                        <dt class="col-sm-4 text-muted">Access Token</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.GithubToken))
                            {
                                <span class="text-muted fst-italic">••••••••••••••••</span>
                                <small class="d-block text-success"><i class="fas fa-shield-alt me-1"></i>Encrypted</small>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Not configured</span>
                            }
                        </dd>
                    </dl>
                    
                    <div class="mt-3">
                        <button type="button" class="btn btn-outline-info btn-sm w-100" id="checkGithubHealthBtn">
                            <i class="fas fa-stethoscope me-1"></i> Check Health (Token)
                        </button>
                    </div>

                    <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3 mt-4">
                        <h6 class="mb-0">Connected Repositories</h6>
                        <a asp-controller="ProjectRepo" asp-action="ManageRepos" class="btn btn-sm btn-outline-dark">
                            <i class="fas fa-cog me-1"></i> Manage
                        </a>
                    </div>

                    @if (Model.GithubRepoUrls != null && Model.GithubRepoUrls.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var repo in Model.GithubRepoUrls)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0 border-0 py-1">
                                    <div class="text-truncate me-2 w-100">
                                        <i class="fas fa-code-branch text-muted me-2"></i>
                                        <a href="@repo" target="_blank" class="text-dark text-decoration-none">@repo</a>
                                    </div>
                                    <span class="badge bg-success rounded-pill" style="font-size: 0.6em">Active</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                         <div class="text-center text-muted py-3">
                             <i class="fab fa-github fa-2x mb-2 opacity-50"></i>
                             <p class="mb-0 small">No repositories connected.</p>
                         </div>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-5 pt-3 border-top text-end">
         <form asp-action="DeleteSettings" method="post" onsubmit="return confirm('WARNING: This will remove all integration settings and repository links. This action cannot be undone. Are you sure?');">
            <input type="hidden" name="groupId" value="@Model.GroupId" />
            <button type="submit" class="btn btn-outline-danger">
                <i class="fas fa-trash-alt me-1"></i> Delete All Configuration
            </button>
        </form>
    </div>
</div>

<div class="toast-container position-fixed top-0 end-0 p-3">
    <div id="healthToast" class="toast align-items-center text-white border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body" id="healthToastBody">
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const toastEl = document.getElementById('healthToast');
            const toastBody = document.getElementById('healthToastBody');
            const toast = new bootstrap.Toast(toastEl);

            const showToast = (type, message) => {
                toastEl.classList.remove('bg-success', 'bg-danger', 'bg-warning');
                toastEl.classList.add(type === 'success' ? 'bg-success' : (type === 'danger' ? 'bg-danger' : 'bg-warning'));
                toastBody.textContent = message;
                toast.show();
            };

            const handleHealthCheck = async (btnId, url, defaultText) => {
                const btn = document.getElementById(btnId);
                if (!btn) return;

                btn.addEventListener('click', async () => {
                    const originalHtml = btn.innerHTML;
                    btn.disabled = true;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Checking...';

                    try {
                        const response = await fetch(url, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' }
                        });
                        
                        // Check if the response is actually valid JSON
                        const contentType = response.headers.get("content-type");
                        if (!contentType || !contentType.includes("application/json")) {
                            throw new Error("Server returned non-JSON response. You might be logged out.");
                        }

                        const result = await response.json();
                        showToast(result.success ? 'success' : 'danger', result.message);
                    } catch (error) {
                        showToast('danger', 'Error connecting to server. ' + error.message);
                    } finally {
                        btn.disabled = false;
                        btn.innerHTML = originalHtml;
                    }
                });
            };

            handleHealthCheck('checkJiraHealthBtn', '@Url.Action("CheckStoredJiraHealth", "ProjectConfig")', '<i class="fas fa-stethoscope me-1"></i> Check Health');
            handleHealthCheck('checkGithubHealthBtn', '@Url.Action("CheckStoredGithubHealth", "ProjectConfig")', '<i class="fas fa-stethoscope me-1"></i> Check Health (Token)');
        });
    </script>
}
