@{
    ViewData["Title"] = "Access Denied";
}

<div class="container text-center mt-5">
    <div class="display-1 text-warning">
        <i class="fas fa-lock"></i>
    </div>
    <h1 class="display-4">Access Denied</h1>
    <p class="lead">You do not have permission to access this page.</p>
    <div class="alert alert-secondary d-inline-block">
        <strong>Reason:</strong> Only designated <strong>Group Leaders</strong> can configure project settings.
    </div>
    <br/>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">Return to Home</a>
</div>
