@model JirHub.MVCWebApp.ViNTD.Models.SaveProjectConfigDto

@{
    ViewData["Title"] = "Project Configuration";
}

<div class="container mt-4">
    <h2>Project Configuration</h2>
    <p class="text-muted">Configure secure Jira and GitHub integrations with encrypted credentials.</p>

    <!-- Success Message -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i>
            <strong>@TempData["SuccessMessage"]</strong>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Error Message -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i>
            <strong>@TempData["ErrorMessage"]</strong>
            @if (TempData["Errors"] != null)
            {
                var errors = TempData["Errors"] as List<string>;
                if (errors != null && errors.Any())
                {
                    <ul class="mb-0 mt-2">
                        @foreach (var error in errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                }
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Alert container for AJAX test connections -->
    <div id="alertContainer"></div>

    <!-- Main Form with Tag Helpers -->
    <form asp-action="SaveSettings" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-users"></i> Group Information</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="GroupId" class="form-label">Group ID (Assigned)</label>
                    <input asp-for="GroupId" class="form-control" readonly />
                    <span asp-validation-for="GroupId" class="text-danger"></span>
                    <div class="form-text">You are configuring the project for your assigned group.</div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="fas fa-tasks"></i> Jira Configuration</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="JiraUrl" class="form-label"></label>
                    <input asp-for="JiraUrl" class="form-control" placeholder="https://yourcompany.atlassian.net" />
                    <div class="form-text">Your Jira instance URL</div>
                    <span asp-validation-for="JiraUrl" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="JiraEmail" class="form-label"></label>
                    <input asp-for="JiraEmail" class="form-control" placeholder="you@example.com" />
                    <div class="form-text">Email associated with your Jira account</div>
                    <span asp-validation-for="JiraEmail" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="JiraApiToken" class="form-label"></label>
                    <input asp-for="JiraApiToken" type="password" class="form-control" />
                    <div class="form-text">
                        Generate from: <a href="https://id.atlassian.com/manage-profile/security/api-tokens" target="_blank">Atlassian API Tokens</a>
                    </div>
                    <span asp-validation-for="JiraApiToken" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="JiraProjectKey" class="form-label"></label>
                    <input asp-for="JiraProjectKey" class="form-control" placeholder="PROJ" maxlength="20" />
                    <div class="form-text">The unique key for your Jira project</div>
                    <span asp-validation-for="JiraProjectKey" class="text-danger"></span>
                </div>

                <button type="button" class="btn btn-outline-info" id="verifyJiraBtn">
                    <i class="fas fa-check-circle"></i> Test Jira Connection
                </button>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="fab fa-github"></i> GitHub Configuration</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="GithubToken" class="form-label"></label>
                    <input asp-for="GithubToken" type="password" class="form-control" />
                    <div class="form-text">
                        Generate from: <a href="https://github.com/settings/tokens" target="_blank">GitHub Tokens</a> (requires 'repo' scope)
                    </div>
                    <span asp-validation-for="GithubToken" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">GitHub Repository URLs</label>
                    <div id="repoContainer">
                        @if (Model?.GithubRepoUrls != null && Model.GithubRepoUrls.Any())
                        {
                            for (var i = 0; i < Model.GithubRepoUrls.Count; i++)
                            {
                                <div class="input-group mb-2">
                                    <input name="GithubRepoUrls" class="form-control" value="@Model.GithubRepoUrls[i]" placeholder="https://github.com/owner/repository" />
                                    <button type="button" class="btn btn-outline-danger remove-repo"><i class="fas fa-trash"></i></button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="input-group mb-2">
                                <input name="GithubRepoUrls" class="form-control" placeholder="https://github.com/owner/repository" />
                                <button type="button" class="btn btn-outline-danger remove-repo" style="display:none;"><i class="fas fa-trash"></i></button>
                            </div>
                        }
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="addRepoBtn">
                        <i class="fas fa-plus"></i> Add Another Repository
                    </button>
                    <div class="form-text">Format: https://github.com/owner/repository</div>
                </div>

                <div class="mb-3">
                    <button type="button" class="btn btn-outline-dark" id="verifyGitHubBtn">
                        <i class="fas fa-check-circle"></i> Test Connection (First Repo)
                    </button>
                </div>
            </div>
        </div>

        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-success btn-lg">
                <i class="fas fa-shield-alt"></i> Save Configuration (Encrypted)
            </button>
            @if(Model?.GroupId > 0 && !string.IsNullOrEmpty(Model.JiraUrl))
            {
                <button type="submit" asp-action="DeleteSettings" formnovalidate class="btn btn-danger btn-lg" onclick="return confirm('Are you sure you want to delete this configuration?');">
                    <i class="fas fa-trash-alt"></i> Delete Configuration
                </button>
            }
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Home
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // Test Jira Connection (AJAX - remains for quick testing)
        document.getElementById('verifyJiraBtn').addEventListener('click', async () => {
            const btn = document.getElementById('verifyJiraBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Testing...';

            const data = {
                jiraUrl: document.querySelector('input[name="JiraUrl"]').value,
                jiraEmail: document.querySelector('input[name="JiraEmail"]').value,
                jiraApiToken: document.querySelector('input[name="JiraApiToken"]').value,
                jiraProjectKey: document.querySelector('input[name="JiraProjectKey"]').value
            };

            try {
                const response = await fetch('/ProjectConfig/VerifyJiraConnection', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                showAlert(result.success ? 'success' : 'warning', result.message);
            } catch (error) {
                showAlert('danger', 'Failed to test connection', [error.message]);
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check-circle"></i> Test Jira Connection';
            }
        });

        // GitHub Repository Management
        const repoContainer = document.getElementById('repoContainer');
        const addRepoBtn = document.getElementById('addRepoBtn');

        addRepoBtn.addEventListener('click', () => {
            const div = document.createElement('div');
            div.className = 'input-group mb-2';
            div.innerHTML = `
                <input name="GithubRepoUrls" class="form-control" placeholder="https://github.com/owner/repository" />
                <button type="button" class="btn btn-outline-danger remove-repo"><i class="fas fa-trash"></i></button>
            `;
            repoContainer.appendChild(div);
            updateRemoveButtons();
        });

        repoContainer.addEventListener('click', (e) => {
            if (e.target.closest('.remove-repo')) {
                e.target.closest('.input-group').remove();
                updateRemoveButtons();
            }
        });

        function updateRemoveButtons() {
            const buttons = repoContainer.querySelectorAll('.remove-repo');
            if (buttons.length === 1) { // Only one repo left
                // Actually, the template had display:none for first one? 
                // Let's just say we always allow removing if index > 0, relying on user common sense not to remove the last one entirely or UI logic.
                // The DTO requires MinLength(1). Let's implement logic to show/hide.
                // If only one input, hide delete.
            }
            // Simple logic: if count == 1, hide button.
            const groups = repoContainer.querySelectorAll('.input-group');
            groups.forEach(g => {
                const btn = g.querySelector('.remove-repo');
                if (groups.length === 1) btn.style.display = 'none';
                else btn.style.display = 'block';
            });
        }
        
        // Initial check
        updateRemoveButtons();

        // Test GitHub Connection (AJAX - modified for list)
        document.getElementById('verifyGitHubBtn').addEventListener('click', async () => {
            const btn = document.getElementById('verifyGitHubBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Testing...';

            // Get first non-empty repo URL
            const inputs = document.querySelectorAll('input[name="GithubRepoUrls"]');
            let firstUrl = '';
            for (let input of inputs) {
                if (input.value.trim()) {
                    firstUrl = input.value;
                    break;
                }
            }

            const data = {
                githubToken: document.querySelector('input[name="GithubToken"]').value,
                githubRepoUrl: firstUrl // Send single URL for testing
            };

            try {
                const response = await fetch('/ProjectConfig/VerifyGitHubConnection', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                showAlert(result.success ? 'success' : 'warning', result.message);
            } catch (error) {
                showAlert('danger', 'Failed to test connection', [error.message]);
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check-circle"></i> Test Connection (First Repo)';
            }
        });

        // Helper function to show alerts (for AJAX test operations only)
        function showAlert(type, message, errors = []) {
            const alertHtml = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    <strong>${message}</strong>
                    ${errors.length > 0 ? '<ul class="mb-0 mt-2">' + errors.map(e => `<li>${e}</li>`).join('') + '</ul>' : ''}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            document.getElementById('alertContainer').innerHTML = alertHtml;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
}
