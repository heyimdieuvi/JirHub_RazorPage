@using JirHub.MVCWebApp.ViNTD.Models
@model LoginRequest

@{
    Layout = null; // Ensuring standalone page
    ViewData["Title"] = "Sign In";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JirHub.ViNTD</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        body {
            background-color: #f0f2f5;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            border: none;
            border-radius: 1rem;
            box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.1);
            max-width: 450px;
            width: 100%;
            background-color: white;
            overflow: hidden;
        }
        .login-header {
            background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);
            padding: 2rem 1.5rem;
            text-align: center;
            color: white;
        }
        .login-body {
            padding: 2.5rem;
        }
    </style>
</head>
<body>
    <div class="container d-flex justify-content-center">
        <div class="login-card animate-fade-in">
            <div class="login-header">
                <i class="fas fa-project-diagram fa-3x mb-2"></i>
                <h4 class="mb-0 fw-bold">JirHub.ViNTD</h4>
                <p class="mb-0 small opacity-75">Connect your Workflow</p>
            </div>
            
            <div class="login-body">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show text-center py-2 text-small" role="alert">
                        <i class="fas fa-exclamation-circle me-1"></i> @TempData["ErrorMessage"]
                        <button type="button" class="btn-close py-2" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-4">
                        <label asp-for="UserName" class="form-label text-muted fw-bold small">USERNAME</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-user text-secondary"></i></span>
                            <input asp-for="UserName" class="form-control border-start-0 bg-light" placeholder="Enter your username" required autofocus />
                        </div>
                        <span asp-validation-for="UserName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label text-muted fw-bold small">PASSWORD</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-lock text-secondary"></i></span>
                            <input asp-for="Password" type="password" class="form-control border-start-0 bg-light" placeholder="Enter your password" required />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                            <i class="fas fa-sign-in-alt me-2"></i> Sign In
                        </button>
                    </div>
                </form>

                <div class="text-center mt-4 pt-3 border-top">
                    <p class="text-muted small mb-1">PRN222 Assignment Project</p>
                    <p class="text-muted small mb-0">&copy; 2026 - <strong>Se181505 (ViNTD)</strong></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>
