@using JirHub.MVCWebApp.ViNTD.Models
@model LoginRequest

@{
    Layout = null; // Ensuring standalone page
    ViewData["Title"] = "Access Denied";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JirHub.ViNTD</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        body {
            background-color: #f8f9fa;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .error-card {
            border: none;
            border-radius: 1rem;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
            max-width: 500px;
            width: 100%;
        }
        .error-icon {
            font-size: 5rem;
            color: #dc3545;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card error-card text-center p-5">
                    <div class="mb-4">
                        <i class="fas fa-ban error-icon"></i>
                    </div>
                    
                    <h1 class="display-6 fw-bold text-danger mb-3">403 - Access Denied</h1>
                    <p class="lead text-muted mb-4">You do not have permission to access the requested resource.</p>
                    
                    <div class="d-grid gap-3">
                        <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-home me-2"></i> Return to Homepage
                        </a>
                        
                        <div class="text-secondary small mt-2">
                             Not your account? <a asp-action="Login" asp-controller="Account" class="text-decoration-none">Log in with a different account</a>
                        </div>
                    </div>
                </div>
                
                <div class="text-center mt-4 text-muted small">
                    <p>&copy; 2026 - <strong>JirHub.ViNTD</strong> - SP26_PRN222_SE1816 - SE181505</p>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
